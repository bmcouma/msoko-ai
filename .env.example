# ─── Msoko AI — Environment Variables Template ───────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to version control.

# ─── Django Core ─────────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-django-key-here
DEBUG=True
ALLOWED_HOSTS=*

# ─── AI / OpenRouter ─────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxx
# Default model for OpenRouter (free tier = "openrouter/auto")
OPENROUTER_MODEL=openrouter/auto

# ─── Database ─────────────────────────────────────────────────────────────────
# Use one of the following:
# --- Option A: SQLite (local dev only) ---
#   No extra config needed; SQLite is the default fallback.
#
# --- Option B: PostgreSQL (production) ---
DATABASE_URL=postgres://msoko_user:msoko_pass@db:5432/msoko_db
# Or set individual vars:
POSTGRES_DB=msoko_db
POSTGRES_USER=msoko_user
POSTGRES_PASSWORD=msoko_pass
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Email (optional, for password reset) ────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=Msoko AI <noreply@msoko.ai>

# ─── Deployment (Railway / Render) ───────────────────────────────────────────
# Set PORT to override the default Gunicorn port
PORT=8000
